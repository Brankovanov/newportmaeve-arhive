# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# =============================================
# Application Environment
# =============================================

# Application environment: development, staging, production
NODE_ENV=development

# Application name
APP_NAME=Newportmaeve Archives

# Application version (leave empty to use package.json version)
APP_VERSION=

# =============================================
# Server Configuration
# =============================================

# Server port for local development
SERVER_PORT=4200

# Server host binding
SERVER_HOST=localhost

# Enable detailed logging
DEBUG=false

# =============================================
# API Configuration
# =============================================

# API base URL for backend services
# Development: http://localhost:3000
# Production: https://api.newportmaeve-archives.com
API_BASE_URL=http://localhost:3000

# API timeout in milliseconds
API_TIMEOUT=30000

# Enable request/response logging
API_LOG_REQUESTS=false

# =============================================
# Authentication
# =============================================

# JWT secret key for token validation
JWT_SECRET=your-secret-key-here-change-in-production

# JWT token expiration time (e.g., 24h, 7d)
JWT_EXPIRATION=24h

# OAuth2 Configuration (if using external auth)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# =============================================
# Database Configuration
# =============================================

# Database connection string
DB_CONNECTION_STRING=

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=newportmaeve_archives

# Database user
DB_USER=

# Database password
DB_PASSWORD=

# =============================================
# Email Configuration
# =============================================

# Email service provider (sendgrid, mailgun, smtp)
EMAIL_PROVIDER=smtp

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@newportmaeve-archives.com

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=

# Mailgun API Key (if using Mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================
# File Storage Configuration
# =============================================

# Storage provider: local, s3, gcs, azure
STORAGE_PROVIDER=local

# Local storage path
STORAGE_LOCAL_PATH=./uploads

# AWS S3 Configuration
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Cloud Storage Configuration
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# =============================================
# Analytics & Monitoring
# =============================================

# Google Analytics 4 Measurement ID
GA_MEASUREMENT_ID=

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# LogRocket Session Replay
LOGROCKET_APP_ID=

# =============================================
# Feature Flags
# =============================================

# Enable/disable features in development
FEATURE_SEARCH_ENABLED=true
FEATURE_ADVANCED_FILTERS_ENABLED=false
FEATURE_RECOMMENDATIONS_ENABLED=false
FEATURE_USER_PROFILES_ENABLED=true

# =============================================
# Security
# =============================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# CSRF token header name
CSRF_HEADER_NAME=X-CSRF-Token

# Rate limiting: requests per window (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=900000

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# =============================================
# SEO Configuration
# =============================================

# Site base URL (used for canonical URLs and sitemap)
SITE_BASE_URL=https://newportmaeve-archives.com

# Default meta description for pages
SEO_DEFAULT_DESCRIPTION=Explore historical archives and collections

# Enable sitemap generation
SEO_GENERATE_SITEMAP=true

# Enable robots.txt
SEO_GENERATE_ROBOTS=true

# =============================================
# Cache Configuration
# =============================================

# Cache provider: redis, memory
CACHE_PROVIDER=memory

# Redis configuration
REDIS_URL=redis://localhost:6379

# Cache TTL (Time to Live) in seconds
CACHE_TTL=3600

# =============================================
# Logging
# =============================================

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=text

# Log file path (optional, leave empty for console only)
LOG_FILE_PATH=./logs/app.log

# =============================================
# Third-party Services
# =============================================

# Image processing service (for thumbnail generation)
IMAGE_PROCESSOR=sharp

# Full-text search service: elasticsearch, meilisearch
SEARCH_SERVICE=meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=

# =============================================
# Development Tools
# =============================================

# Enable hot module replacement (HMR)
HMR_ENABLED=true

# Enable source maps in production
SOURCE_MAPS_ENABLED=false

# Mock API responses in development
MOCK_API=false

# Verbose debug output
VERBOSE_OUTPUT=false
